{
  "name": "MAIN_FIRE_DOMSIN_WORKSPACE",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "genx-cli": "genx-cli/cli.js"
  },
  "scripts": {
    "sync-logs": "python sync_github_logs.py",
    "dev": "concurrently \"npm:client\" \"npm:server\" \"npm:python:dev\"",
    "client": "vite --host 0.0.0.0 --port 5173",
    "server": "tsx --watch --env-file=.env services/server/index.ts",
    "python:dev": "uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload",
    "start": "concurrently \"tsx --env-file=.env services/server/index.ts\" \"uvicorn api.main:app --host 0.0.0.0 --port 8000\"",
    "start:prod": "concurrently \"tsx services/server/index.ts\" \"uvicorn api.main:app --host 0.0.0.0 --port 8000\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.0.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/sandbox": "^1.5.0",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.0",
    "embla-carousel-react": "^8.0.0",
    "express": "^5.2.1",
    "firebase-tools": "^13.9.0",
    "lucide-react": "^0.500.0",
    "nanoid": "^5.1.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.70.0",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.1.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.23.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}