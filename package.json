{
  "name": "genx-fx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "genx-cli": "genx-cli/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:client\" \"pnpm:server\" \"pnpm:python:dev\"",
    "client": "vite --host 0.0.0.0 --port 5173",
    "server": "tsx watch services/server/index.ts",
    "python:dev": "uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload",
    "start": "concurrently \"tsx services/server/index.ts\" \"uvicorn api.main:app --host 0.0.0.0 --port 8000\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.0.0",
    "express": "^5.1.0",
    "firebase-tools": "^15.0.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.500.0",
    "nanoid": "^5.1.6",
    "pg": "^8.17.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.70.0",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.1.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "wouter": "^3.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.27.2",
